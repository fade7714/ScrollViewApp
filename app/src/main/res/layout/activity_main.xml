    <!-- Tytuł -->
    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#5B5BA8"
        android:paddingTop="18dp"
        android:layout_alignParentTop="true">

        <TextView
